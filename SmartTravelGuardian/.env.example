# Roamsafe Global API Keys
# Copy this file to .env and fill in your API keys

# === REQUIRED APIs ===
# Weather Data (Required for weather-based safety alerts)
OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# === OPTIONAL ENHANCEMENT APIs ===
# Global News & Events
NEWS_API_KEY=your_newsapi_key_here
GDELT_API_KEY=not_required_free_api

# Global Crime & Safety Data
NUMBEO_API_KEY=your_numbeo_api_key_here

# Enhanced Mapping & Places
MAPBOX_API_KEY=your_mapbox_api_key_here
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Transportation Data
TRANSITFEEDS_API_KEY=your_transitfeeds_api_key_here

# AI Enhancement
OPENAI_API_KEY=your_openai_api_key_here

# === FREE APIs (No keys required) ===
# These work out of the box:
# - OpenStreetMap Overpass API (global locations)
# - Nominatim Geocoding (global address lookup)
# - US State Department Travel Advisories
# - UK Foreign Office Travel Advice
# - World Bank Data
# - Emergency Numbers Database
# - GDELT Project (global events)

# === APP CONFIGURATION ===
APP_ENV=development
API_TIMEOUT=10000
CACHE_DURATION=1800000
RATE_LIMIT_ENABLED=true